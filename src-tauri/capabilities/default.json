{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "dialog:allow-open",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    }
  ]
}
