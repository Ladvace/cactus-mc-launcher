# Copy this file to `.env` and paste your Azure application (client) ID.
# Register an app at https://portal.azure.com (Entra ID -> App registrations),
# choose "Personal Microsoft accounts only", and enable
# Authentication -> "Allow public client flows".
#
# `.env` is gitignored. Leave AZURE_CLIENT_ID empty to keep Microsoft login
# disabled (offline mode still works).

AZURE_CLIENT_ID=

# Backend base URL (the deployed Cloudflare Worker in `server/`). Enables the
# CurseForge content source, which is proxied through the backend so the API key
# stays server-side. Leave empty to disable CurseForge.
#   e.g. CACTUS_API_BASE=https://cactus-mc-api.<you>.workers.dev
CACTUS_API_BASE=

# The CurseForge API key itself is NOT set here — it lives on the backend
# (server/) as a Worker secret. Giphy is entered by users in Settings.