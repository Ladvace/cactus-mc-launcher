# Copy this file to `.env` and paste your Azure application (client) ID.
# Register an app at https://portal.azure.com (Entra ID -> App registrations),
# choose "Personal Microsoft accounts only", and enable
# Authentication -> "Allow public client flows".
#
# `.env` is gitignored. Leave AZURE_CLIENT_ID empty to keep Microsoft login
# disabled (offline mode still works).

AZURE_CLIENT_ID=

# Optional: enable CurseForge as a content source. Get a free API key at
# https://console.curseforge.com (API Keys). Leave empty to disable CurseForge.
CURSEFORGE_API_KEY=

# (Giphy is not set here — users add their own key in Settings → Interface.)