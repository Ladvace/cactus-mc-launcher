# Launcher frontend config (Vite). Copy to `.env` to enable the online
# Streamers features. Leave unset and the tab stays offline-only (file
# import/export still works). The Rust-side keys live in src-tauri/.env.

# Base URL of the deployed Streamer API (server/) — e.g. your Workers URL.
VITE_STREAMER_API_URL=

# Supabase project (public values) — used for streamer OAuth sign-in.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
CACTUS_API_BASE=
